# ─────────────────────────────────────────────────────────────────────────────
# ADVERSIQ Intelligence — Production Environment Template
# Set these variables in your Railway/Render dashboard (NOT in this file)
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3000

# REQUIRED: Set this to your Railway/Render public URL after first deploy
# e.g. https://adversiq-intelligence.up.railway.app
FRONTEND_URL=

# REQUIRED: Change this to any long random string (64+ characters)
JWT_SECRET=change-me-to-a-random-64-char-string-in-production

# ─── AI Providers (add at least ONE) ─────────────────────────────────────────
# FREE: Groq — get key at https://console.groq.com (no credit card)
GROQ_API_KEY=

# FREE: Google Gemini — get key at https://aistudio.google.com (no credit card)
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# PAID (optional): OpenAI
# OPENAI_API_KEY=

# PAID (optional): Anthropic
# ANTHROPIC_API_KEY=

# PAID (optional): Together.ai
# TOGETHER_API_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_USE_REAL_AI=true
VITE_USE_REAL_DATA=true
VITE_USE_REAL_BACKEND=true
VITE_SHOW_DEMO_INDICATORS=false
VITE_ENABLE_SELF_LEARNING=true
VITE_ENABLE_EXTERNAL_DATA=true

# ─── Autonomous Mode ──────────────────────────────────────────────────────────
AUTONOMOUS_MODE_DEFAULT=true
AUTO_ACT_ENABLED=true

# ─── Timeouts (production values) ────────────────────────────────────────────
CONSULTANT_ORCHESTRATOR_TIMEOUT_MS=30000
CONSULTANT_PROVIDER_TIMEOUT_MS=35000

# ─── Database (optional — system works without it) ───────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
