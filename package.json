{
  "name": "bw-nexus-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "build": "npm run build:all",
    "build:client": "vite build",
    "security:scan-dist": "node scripts/scan-dist-secrets.js",
    "build:secure": "npm run build && npm run security:scan-dist",
    "build:server": "node scripts/build-server.js",
    "build:all": "npm run build:client && npm run build:server",
    "start": "node dist-server/server/index.js",
    "preview": "npm run build:client && vite preview",
    "test:nsil": "tsx scripts/nsilSimulation.ts",
    "test:interaction-stress": "tsx scripts/interactionStress100.ts",
    "live:global-matters": "tsx scripts/liveGlobalMatterRun.ts",
    "test:government-investment-scenarios": "tsx scripts/runRealWorldInvestmentScenarios.ts",
    "audit:continual-harness": "tsx scripts/auditContinualHarness.ts",
    "test:system": "tsx scripts/testFullSystem.ts",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:consultant": "tsx --test tests/consultant-behavior.test.ts tests/consultant-capabilities.test.ts tests/augmented-ai-support.test.ts tests/overlooked-first-engine.test.ts tests/strategic-intelligence-pipeline.test.ts tests/brain-coverage-audit.test.ts",
    "audit:unused:exports": "ts-prune -p tsconfig.json",
    "audit:unused:deps": "depcheck",
    "audit:cycles": "madge --extensions ts,tsx --circular ./",
    "audit:all": "npm run audit:unused:exports && npm run audit:unused:deps && npm run audit:cycles"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1013.0",
    "@google/genai": "^1.30.0",
    "@google/generative-ai": "^0.24.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^2.1.0",
    "axios": "^1.13.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.23.25",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "mathjs": "^12.4.0",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.5.207",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.5.1",
    "serverless-http": "^3.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "depcheck": "^1.4.7",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "madge": "^8.0.0",
    "playwright": "^1.57.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.19.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
